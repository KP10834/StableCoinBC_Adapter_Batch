{
  "name": "stablecoin-bc-adapter-batch",
  "version": "1.0.0",
  "description": "Batch jobs for StableCoin BC Adapter (balance monitoring, etc.)",
  "main": "dist/index.js",
  "engines": {
    "node": "22.22.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev:balance": "tsx --env-file=.env src/jobs/balance/index.ts",
    "start:balance": "node --env-file=.env dist/jobs/balance/index.js",
    "dev:health": "tsx --env-file=.env src/jobs/health-check/index.ts",
    "start:health": "node --env-file=.env dist/jobs/health-check/index.js",
    "dev:pending-tx": "tsx --env-file=.env src/jobs/pending-tx/index.ts",
    "start:pending-tx": "node --env-file=.env dist/jobs/pending-tx/index.js",
    "dev:block-scan": "tsx --env-file=.env src/jobs/block-scan-verify/index.ts",
    "start:block-scan": "node --env-file=.env dist/jobs/block-scan-verify/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "ethers": "^6.16.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "tsc-alias": "^1.8.15",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
