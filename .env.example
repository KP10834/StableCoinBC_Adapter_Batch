# ── Hot Wallet ──
HOT_WALLET_ADDRESS=0xA3bcFB479f4e9Eca3F4aB01C3BdAc162dE4A1503

# ── Config DB (Adapter의 config.db 경로) ──
CONFIG_DATABASE_URL=file:../StableCoinBC_Adapter/data/config.db

# ── RPC ──
RPC_TIMEOUT_MS=5000

# ── 잔액 임계값 (이하이면 WARN 로그) ──
THRESHOLD_NATIVE=0.1
THRESHOLD_TOKEN=10

# ── Health Check ──
ADAPTER_HEALTH_URL=http://localhost:8081/health
ADAPTER_WS_URL=ws://localhost:8080/ws
HEALTH_CHECK_TIMEOUT_MS=5000

# ── Pending TX ──
OUTBOX_DATABASE_URL=file:../StableCoinBC_Adapter/data/outbox.db
PENDING_TX_THRESHOLD_MINUTES=10

# ── Block Scan Verify ──
LISTENER_STATE_DIR=../StableCoinBC_Adapter_Listener/.state
BLOCK_LAG_THRESHOLD=100

# ── 로그 ──
LOG_LEVEL=info
LOG_PRETTY=true
LOG_COLORIZE=false
